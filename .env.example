# Twilio Configuration
TWILIO_ACCOUNT_SID=your_twilio_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
YOUR_CELL_NUMBER=whatsapp:+11234567890

# Google Maps API
MAPS_API_KEY=your_google_maps_api_key_here
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Default Locations (used as fallbacks in traffic_agent.py)
HOME_ADDRESS=Your Home Address
OFFICE_ADDRESS=Your Office Address

# GitHub Configuration (for Twilio function to trigger workflows)
GITHUB_TOKEN=your_github_personal_access_token
GITHUB_REPO=your_username/traffic-agent
WORKFLOW_FILE=traffic-analysis.yml
